# Gemini API 配置（用于过滤，必填）
GEMINI_API_KEY=     # 必填：Google Gemini API Key
GEMINI_MODEL=       # 必填：过滤用模型名，如 gemini-3.1-flash-lite-preview
GEMINI_CONCURRENCY=200  # 可选：过滤并发数，默认 200

# OpenAI 兼容 API 配置（用于报告生成，必填）
AI_API_KEY=         # 必填：OpenAI 兼容 API Key
AI_BASE_URL=        # 必填：OpenAI 兼容 API 地址
AI_SONNET_MODEL=    # 必填：报告生成用模型名，如 claude-sonnet-4-6
